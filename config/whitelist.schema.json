{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kotisatama whitelist",
  "type": "object",
  "required": ["domains"],
  "additionalProperties": false,
  "properties": {
    "domains": {
      "type": "array",
      "description": "Allowed registrable domains. Subdomains are allowed automatically.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  }
}
